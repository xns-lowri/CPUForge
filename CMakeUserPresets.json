{
  "version": 3,
  "configurePresets": [
    {
      "name": "default",
      "inherits": "vcpkg",
      "environment": {
        "VCPKG_ROOT": "$VCPKG_ROOT"
      }
    },
    {
      "name": "macos",
      "inherits": "vcpkg",
      "environment": {
        "VCPKG_ROOT": "~/vcpkg"
      }
    }
  ]
}